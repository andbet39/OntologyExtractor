{
  "name": "ontology-extractor",
  "version": "0.1.0",
  "description": "Provider-agnostic TBox extraction from document corpora",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./langchain": {
      "types": "./dist/langchain/index.d.ts",
      "import": "./dist/langchain/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@langchain/core": "1.2.3"
  },
  "peerDependencies": {
    "@langchain/core": "1.2.3"
  },
  "peerDependenciesMeta": {
    "@langchain/core": {
      "optional": true
    }
  }
}