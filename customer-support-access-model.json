  "policies": [
    {
      "name": "Support can read regional customers",
      "status": "ACTIVE",
      "order": 1,
      "securityProfileRef": "support-operations-access",
      "policyType": "ENTITY_LEVEL",
      "effect": "GRANT",
      "actions": [
        "READ"
      ],
      "definition": {
        "target": {
          "type": "ENTITY",
          "ref": "customer"
        },
        "conditions": {
          "mode": "CNF",
          "groups": [
            {
              "conditions": [
                {
                  "left": {
                    "key": "department",
                    "source": "USER"
                  },
                  "right": {
                    "value": "Support",
                    "source": "STATIC",
                    "valueType": "STRING"
                  },
                  "operator": "EQ"
                }
              ]
            },
            {
              "conditions": [
                {
                  "left": {
                    "key": "location",
                    "source": "USER"
                  },
                  "right": {
                    "value": "EMEA",
                    "source": "STATIC",
                    "valueType": "STRING"
                  },
                  "operator": "EQ"
                },
                {
                  "left": {
                    "key": "location",
                    "source": "USER"
                  },
                  "right": {
                    "value": "NA",
                    "source": "STATIC",
                    "valueType": "STRING"
                  },
                  "operator": "EQ"
                }
              ]
            }
          ]
        },
        "description": "Support users can read customers when their user profile is in a supported location."
      }
    },
    {
      "name": "Support can manage tickets",
      "status": "ACTIVE",
      "order": 2,
      "securityProfileRef": "support-operations-access",
      "policyType": "ENTITY_LEVEL",
      "effect": "GRANT",
      "actions": [
        "CREATE",
        "READ",
        "UPDATE"
      ],
      "definition": {
        "target": {
          "type": "ENTITY",
          "ref": "supportticket"
        },
        "conditions": {
          "mode": "CNF",
          "groups": [
            {
              "conditions": [
                {
                  "left": {
                    "key": "department",
                    "source": "USER"
                  },
                  "right": {
                    "value": "Support",
                    "source": "STATIC",
                    "valueType": "STRING"
                  },
                  "operator": "EQ"
                }
              ]
            },
            {
              "conditions": [
                {
                  "left": {
                    "key": "external",
                    "source": "USER"
                  },
                  "right": {
                    "value": false,
                    "source": "STATIC",
                    "valueType": "BOOLEAN"
                  },
                  "operator": "EQ"
                }
              ]
            },
            {
              "conditions": [
                {
                  "left": {
                    "key": "location",
                    "source": "USER"
                  },
                  "right": {
                    "value": "EMEA",
                    "source": "STATIC",
                    "valueType": "STRING"
                  },
                  "operator": "EQ"
                },
                {
                  "left": {
                    "key": "location",
                    "source": "USER"
                  },
                  "right": {
                    "value": "NA",
                    "source": "STATIC",
                    "valueType": "STRING"
                  },
                  "operator": "EQ"
                }
              ]
            }
          ]
        },
        "description": "Support users can create, read, and update tickets when their user profile is in a supported location."
      }
    },
