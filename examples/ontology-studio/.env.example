# Provider: mock | lmstudio | azure
ONTOLOGY_PROVIDER=mock

# LM Studio (OpenAI-compatible local server)
LMSTUDIO_BASE_URL=http://localhost:1234/v1
LMSTUDIO_CHAT_MODEL=
LMSTUDIO_EMBEDDING_MODEL=
LMSTUDIO_API_KEY=lm-studio
ONTOLOGY_EMBEDDING_DIMENSIONS=

# Azure OpenAI
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_VERSION=2024-10-21
AZURE_OPENAI_CHAT_DEPLOYMENT=
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=

# Upload limits
ONTOLOGY_MAX_FILES=20
ONTOLOGY_MAX_FILE_BYTES=2097152
ONTOLOGY_MAX_TOTAL_BYTES=20971520

# Session limits
ONTOLOGY_MAX_ACTIVE_SESSIONS=10
ONTOLOGY_SESSION_TTL_MS=3600000

# Extraction defaults
ONTOLOGY_SUPPORT_THRESHOLD=1
ONTOLOGY_EXTRACTION_ACCURACY=medium
